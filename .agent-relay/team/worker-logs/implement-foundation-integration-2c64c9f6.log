+      sessionId: session.id,
+      text: 'hello',
+    });
+
+    expect((await store.get(session.id))?.attachedSurfaces).toEqual(['surface-b']);
+    expect(adapters.sent).toEqual([
+      { sessionId: session.id, text: 'hello', surfaceId: 'surface-b' },
+    ]);
+  });
+});
