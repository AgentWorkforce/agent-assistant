+  return {
+    sent,
+    async send(payload) {
+      sent.push(payload);
+    },
+    onConnect(callback) {
+      connectHandlers.add(callback);
+    },
+    onDisconnect(callback) {
+      disconnectHandlers.add(callback);
+    },
+    triggerConnect() {
+      for (const callback of connectHandlers) {
