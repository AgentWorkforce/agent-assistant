      surfaceId,
      messageId,
    });
    return null;
  }

  if (text.length === 0) {
    console.warn('Inbound message text missing; using empty string', {
      surfaceId,
      messageId,
    });
  }

  return {
    id: messageId,
    surfaceId,
    sessionId,
    userId,
    workspaceId,
    text,
    raw,
    receivedAt,
    capability,
  };
}

