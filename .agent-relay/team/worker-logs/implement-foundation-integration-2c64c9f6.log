    });
    registry.register(connection);

    await expect(registry.send(createEvent())).rejects.toMatchObject({
      surfaceId: 'surface-a',
      cause,
    });
  });
});

describe('fanout', () => {
  it('delivers concurrently to all active attached surfaces', async () => {
