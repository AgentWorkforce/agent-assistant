   136	
   137	  /**
   138	   * Register a callback to be invoked when the connection becomes active.
   139	   * Called once immediately if already active.
   140	   */
   141	  onConnect(callback: () => void): void;
   142	
   143	  /**
   144	   * Register a callback to be invoked when the connection becomes inactive.
   145	   */
