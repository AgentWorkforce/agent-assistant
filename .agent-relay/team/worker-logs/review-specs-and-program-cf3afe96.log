   216	
   217	  /**
   218	   * Fanout an OutboundEvent to all surfaces attached to a session.
   219	   * Reads attached surfaces from the provided session object.
   220	   * Returns a FanoutResult describing per-surface delivery outcomes.
   221	   */
   222	  fanout(event: OutboundEvent, attachedSurfaceIds: string[], policy?: FanoutPolicy): Promise<FanoutResult>;
   223	}
