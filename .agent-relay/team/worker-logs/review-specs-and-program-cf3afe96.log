   177	 * Products provide these; surfaces package defines the contract.
   178	 */
   179	export type SurfaceFormatHook = (
   180	  event: OutboundEvent,
   181	  capabilities: SurfaceCapabilities,
   182	) => Promise<unknown> | unknown;
