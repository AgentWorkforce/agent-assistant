   181	  if (!isNonEmptyString(plan.intent)) {
   182	    errors.push('plan.intent must be a non-empty string');
   183	  }
   184	
   185	  if (!Array.isArray(plan.steps) || plan.steps.length === 0) {
   186	    errors.push('plan.steps must contain at least one step');
   187	  }
   188	
   189	  if (plan.steps.length > maxSteps) {
   190	    errors.push(`plan.steps exceeds maxSteps (${maxSteps})`);
   191	  }
   192	
   193	  for (const [index, step] of plan.steps.entries()) {
   194	    if (!isNonEmptyString(step.specialistName)) {
   195	      errors.push(`plan.steps[${index}].specialistName must be a non-empty string`);
   196	      continue;
   197	    }
   198	
   199	    if (!registry.has(step.specialistName)) {
   200	      errors.push(`plan.steps[${index}] references unknown specialist ${step.specialistName}`);
   201	    }
   202	
   203	    if (!isNonEmptyString(step.instruction)) {
   204	      errors.push(`plan.steps[${index}].instruction must be a non-empty string`);
   205	    }
   206	  }
   207	
   208	  return {
   209	    valid: errors.length === 0,
   210	    errors,
   211	  };
   212	}
