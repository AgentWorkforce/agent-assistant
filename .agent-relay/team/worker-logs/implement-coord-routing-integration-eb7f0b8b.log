import type { ConnectivitySignal, SignalCallback } from '@relay-assistant/connectivity';

import {
  CoordinationBlockedError,
  CoordinationError,
  DelegationPlanError,
  SpecialistConflictError,
  SpecialistNotFoundError,
  SynthesisError,
} from './types.js';
import type {
  CoordinationSignals,
