   174	export function validateDelegationPlan(
   175	  plan: DelegationPlan,
   176	  registry: SpecialistRegistry,
   177	  maxSteps = DEFAULT_MAX_STEPS,
   178	): DelegationPlanValidation {
   179	  const errors: string[] = [];
