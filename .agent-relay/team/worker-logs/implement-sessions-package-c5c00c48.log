+      userId: 'user-1',
+      initialSurfaceId: 'surface-a',
+    });
+    await store.attachSurface('session-1', 'surface-b');
+
+    const detached = await store.detachSurface('session-1', 'surface-a');
+    const repeated = await store.detachSurface('session-1', 'surface-a');
+
