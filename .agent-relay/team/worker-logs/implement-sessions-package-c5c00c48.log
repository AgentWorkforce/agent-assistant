+
+    expect(sessions).toHaveLength(1);
+    expect(sessions[0]?.userId).toBe('user-1');
+    expect(sessions[0]?.state).toBe('active');
+    vi.useRealTimers();
+  });
+});
+
+describe('lifecycle transitions', () => {
