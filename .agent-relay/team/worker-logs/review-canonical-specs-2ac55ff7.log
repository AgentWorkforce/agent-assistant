    73	
    74	  /**
    75	   * Optional workspace scope. When set, session is scoped to both user and
    76	   * workspace. Memory retrieval uses this to narrow scope.
    77	   */
    78	  workspaceId?: string;
    79	
    80	  /** Current lifecycle state. */

