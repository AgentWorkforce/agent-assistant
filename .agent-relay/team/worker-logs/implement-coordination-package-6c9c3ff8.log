  callbacks: Set<SignalCallback>,
  signal: ConnectivitySignal,
  event: SignalEvent,
): void {
  for (const callback of callbacks) {
    try {
      callback(signal, event);
    } catch (error) {
      console.error('Connectivity signal callback failed', error);
    }
  }
