+{
+  "name": "@relay-assistant/coordination",
+  "version": "0.1.0",
+  "description": "Minimal coordinator, specialist registry, delegation, and synthesis runtime for Relay Agent Assistant",
+  "type": "module",
+  "main": "dist/index.js",
+  "types": "dist/index.d.ts",
+  "exports": {
+    ".": {
+      "import": "./dist/index.js",
+      "types": "./dist/index.d.ts"
+    }
+  },
+  "files": [
+    "dist"
+  ],
+  "scripts": {
+    "prebuild": "npm --prefix ../connectivity run build",
+    "build": "tsc -p tsconfig.json",
+    "pretest": "npm --prefix ../connectivity run build",
+    "test": "vitest run",
+    "test:watch": "vitest"
+  },
+  "dependencies": {
+    "@relay-assistant/connectivity": "file:../connectivity",
+    "nanoid": "^5.1.6"
+  },
+  "devDependencies": {
+    "typescript": "^5.9.3",
+    "vitest": "^3.2.4"
+  }
+}
