@@ -0,0 +1,38 @@
+export {
+  createCoordinator,
+  createDelegationPlan,
+  createSpecialistRegistry,
+  createSynthesizer,
+  validateDelegationPlan,
+} from './coordination.js';
+
+export {
+  CoordinationBlockedError,
+  CoordinationError,
+  DelegationPlanError,
+  SpecialistConflictError,
+  SpecialistNotFoundError,
+  SynthesisError,
+} from './types.js';
+
+export type {
+  CoordinationSignals,
+  CoordinationTurn,
+  Coordinator,
+  CoordinatorConfig,
+  DelegationPlan,
+  DelegationPlanValidation,
+  DelegationStep,
+  Specialist,
