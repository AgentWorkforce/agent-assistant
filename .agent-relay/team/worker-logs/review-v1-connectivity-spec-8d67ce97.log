   460	export interface ConnectivityLayerConfig {
   461	  /**
   462	   * Suppression window configuration.
   463	   * Defaults to step-basis if omitted.
   464	   */
   465	  suppressionConfig?: SuppressionConfig;
   466	
   467	  /**
   468	   * Routing escalation hook. Optional.
   469	   * When registered, called synchronously on escalation signal emit.
   470	   */
