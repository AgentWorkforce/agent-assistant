   330	  query(query: SignalQuery): ConnectivitySignal[];
   331	
   332	  /**
   333	   * Advance the step counter for a thread.
   334	   * Signals with expiresAtStep <= current step transition to 'expired'.
   335	   * onSignal fires with event='expired' for each.
   336	   */
   337	  advanceStep(threadId: string): void;
   338	
   339	  /**
   340	   * Register a SelectedAudienceResolver for audience='selected' signals.
   341	   * Only one resolver is active at a time; subsequent calls replace the previous.
   342	   * Called by coordination during initialization.
   343	   */
   344	  registerSelectedResolver(resolver: SelectedAudienceResolver): void;
   345	
   346	  /**
   347	   * Register a callback invoked on every signal state transition event.
   348	   * Events: 'emitted', 'superseded', 'resolved', 'expired'.
   349	   */
   350	  onSignal(callback: SignalCallback): void;
   351	
   352	  /** Remove a previously registered callback. No-op if callback is not registered. */
   353	  offSignal(callback: SignalCallback): void;
   354	}
   355	```
   356	
   357	### 8.1 `SignalQuery`
   358	
   359	```typescript
   360	export interface SignalQuery {
   361	  threadId: string;
   362	
   363	  /** Filter by emitting source component ID. */
   364	  source?: string;
   365	
   366	  /** Filter by message class (single or array). */
