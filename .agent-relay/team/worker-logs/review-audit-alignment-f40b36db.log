   155	**Sage v1 minimum viable assembly:**
   156	
   157	```ts
   158	import { createAssistant } from "@relay-assistant/core";
   159	import type { AssistantDefinition, InboundMessage, CapabilityContext } from "@relay-assistant/core";
   160	import { createSessionStore, InMemorySessionStoreAdapter, resolveSession, createDefaultAffinityResolver } from "@relay-assistant/sessions";
   161	import type { SessionStore } from "@relay-assistant/sessions";
   162	import { createSurfaceRegistry } from "@relay-assistant/surfaces";
   163	import type { SurfaceConnection, SurfaceCapabilities } from "@relay-assistant/surfaces";
   164	
   165	// 1. Define the Sage assistant
   166	const definition: AssistantDefinition = {
   167	  id: "sage",
   168	  name: "Sage",
   169	  capabilities: {
   170	    chat: async (message: InboundMessage, context: CapabilityContext) => {
   171	      const store = context.runtime.get<SessionStore>("sessions");
   172	      const session = await resolveSession(
   173	        message,
   174	        store,
   175	        createDefaultAffinityResolver(store),
   176	      );
   177	      await store.touch(session.id);
   178	
   179	      // Sage domain handler — product-owned logic
   180	      await context.runtime.emit({
   181	        surfaceId: message.surfaceId,
   182	        sessionId: session.id,
   183	        text: "...", // Sage-specific response
   184	      });
   185	    },
   186	  },
   187	};
   188	
   189	// 2. Wire sessions
   190	const sessionStore = createSessionStore({
   191	  adapter: new InMemorySessionStoreAdapter(),
   192	});
   193	
   194	// 3. Wire surfaces
   195	const slackCapabilities: SurfaceCapabilities = {
   196	  markdown: false,
   197	  richBlocks: true,
   198	  attachments: true,
   199	  streaming: false,
   200	  maxResponseLength: 3000,
   201	};
   202	
   203	const slackConnection: SurfaceConnection = {
   204	  id: "sage-slack",
   205	  type: "slack",
   206	  state: "registered",
   207	  capabilities: slackCapabilities,
   208	  adapter: stubSlackAdapter, // provided by relay foundation or product code
   209	  formatHook: (event, caps) => ({ blocks: [{ type: "section", text: event.text }] }),
   210	};
   211	
   212	const surfaceRegistry = createSurfaceRegistry();
   213	surfaceRegistry.register(slackConnection);
   214	
   215	// 4. Create runtime and register subsystems
   216	const runtime = createAssistant(definition, {
   217	  inbound: surfaceRegistry,
   218	  outbound: surfaceRegistry,
   219	});
   220	runtime.register("sessions", sessionStore);
   221	
   222	await runtime.start();
   223	```
