+  | "attention.requested"
+  | "salience.delta"
+  | "confidence.high"
+  | "confidence.low"
+  | "uncertainty.blocker"
+  | "conflict.detected"
+  | "consensus.reached"
+  | "handoff.ready"
+  | "handoff.blocked"
+  | "escalation.required"
