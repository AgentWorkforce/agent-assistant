+
+    expect(criticalB.id).not.toBe(criticalA.id);
+    expect(highB.id).not.toBe(highA.id);
+  });
+
+  it('supports time-basis suppression windows', () => {
+    vi.useFakeTimers();
+    vi.setSystemTime(new Date('2026-04-11T00:00:00.000Z'));
