+    const suppressed = layer.emit(baseInput({ summary: 'A different summary still suppresses' }));
+
+    expect(suppressed.id).toBe(first.id);
+    expect(layer.query({ threadId: 'thread-1', state: ['emitted', 'active'] })).toHaveLength(1);
