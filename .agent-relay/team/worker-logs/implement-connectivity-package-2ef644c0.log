+    const highB = layer.emit(
+      baseInput({
+        messageClass: 'escalation',
+        signalClass: 'escalation.uncertainty',
+        priority: 'high',
+        confidence: undefined,
+        summary: 'Need deeper routing for ambiguity B',
+      }),
