-  signalClass: SignalClass,
-  priority: 'low' | 'normal' | 'high' | 'critical',
-  summary: string,
-  confidence?: number,      // required for confidence.* and conflict.*
-  details?: string,
-  replaces?: string,        // supersedes the target signal
