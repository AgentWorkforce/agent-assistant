+function createMessage(overrides: Partial<InboundMessage> = {}): InboundMessage {
+  return {
+    id: 'msg-1',
+    surfaceId: 'surface-a',
+    sessionId: 'session-1',
+    userId: 'user-1',
+    workspaceId: 'workspace-1',
+    text: 'hello',
+    raw: { source: 'test' },
+    receivedAt: '2026-04-11T00:00:00.000Z',
+    capability: 'reply',
+    ...overrides,
+  };
