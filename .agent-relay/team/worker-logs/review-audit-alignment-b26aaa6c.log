   155	
   156	**Sage v1 minimum viable assembly:**
   157	
   158	```ts
   159	import { createAssistant } from "@relay-assistant/core";
   160	import type { AssistantDefinition, InboundMessage, CapabilityContext } from "@relay-assistant/core";
   161	import { createSessionStore, InMemorySessionStoreAdapter, resolveSession, createDefaultAffinityResolver } from "@relay-assistant/sessions";
   162	import type { SessionStore } from "@relay-assistant/sessions";
   163	import { createSurfaceRegistry } from "@relay-assistant/surfaces";
   164	import type { SurfaceConnection, SurfaceCapabilities } from "@relay-assistant/surfaces";
   165	
   166	// 1. Define the Sage assistant
   167	const definition: AssistantDefinition = {
   168	  id: "sage",
   169	  name: "Sage",
   170	  capabilities: {
   171	    chat: async (message: InboundMessage, context: CapabilityContext) => {
   172	      const store = context.runtime.get<SessionStore>("sessions");
   173	      const session = await resolveSession(
   174	        message,
   175	        store,
   176	        createDefaultAffinityResolver(store),
   177	      );
   178	      await store.touch(session.id);
   179	
   180	      // Sage domain handler — product-owned logic
   181	      await context.runtime.emit({
   182	        surfaceId: message.surfaceId,
   183	        sessionId: session.id,
   184	        text: "...", // Sage-specific response
   185	      });
   186	    },
   187	  },
   188	};
   189	
   190	// 2. Wire sessions
   191	const sessionStore = createSessionStore({
   192	  adapter: new InMemorySessionStoreAdapter(),
   193	});
   194	
   195	// 3. Wire surfaces
   196	const slackCapabilities: SurfaceCapabilities = {
   197	  markdown: false,
   198	  richBlocks: true,
   199	  attachments: true,
   200	  streaming: false,
   201	  maxResponseLength: 3000,
   202	};
   203	
   204	const slackConnection: SurfaceConnection = {
   205	  id: "sage-slack",
   206	  type: "slack",
   207	  state: "registered",
   208	  capabilities: slackCapabilities,
   209	  adapter: stubSlackAdapter, // provided by relay foundation or product code
   210	  formatHook: (event, caps) => ({ blocks: [{ type: "section", text: event.text }] }),
   211	};
   212	
   213	const surfaceRegistry = createSurfaceRegistry();
   214	surfaceRegistry.register(slackConnection);
   215	
   216	// 4. Create runtime and register subsystems
   217	const runtime = createAssistant(definition, {
   218	  inbound: surfaceRegistry,
   219	  outbound: surfaceRegistry,
   220	});
   221	runtime.register("sessions", sessionStore);
   222	
   223	await runtime.start();
   224	```
