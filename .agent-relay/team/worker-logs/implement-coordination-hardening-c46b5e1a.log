          if (!specialist) {
            throw new SpecialistNotFoundError(step.specialistName);
          }

          try {
            const rawResult = await specialist.handler.execute(step.instruction, {
              turnId,
              threadId,
              stepIndex,
              plan: normalizedPlan,
              priorResults: results.map(cloneResult),
              connectivity: config.connectivity,

