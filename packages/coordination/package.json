{
  "name": "@agent-assistant/coordination",
  "version": "0.3.6",
  "description": "Minimal coordinator, specialist registry, delegation, and synthesis runtime for Agent Assistant SDK",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "npm run build",
    "prebuild": "npm --prefix ../routing run build && npm --prefix ../connectivity run build",
    "build": "tsc -p tsconfig.json",
    "pretest": "npm --prefix ../routing run build && npm --prefix ../connectivity run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@agent-assistant/connectivity": "^0.2.6",
    "nanoid": "^5.1.6"
  },
  "devDependencies": {
    "@agent-assistant/routing": "file:../routing",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentWorkforce/agent-assistant"
  },
  "publishConfig": {
    "access": "public"
  }
}
