    "@agent-assistant/harness": "^0.3.8"
  },
  "peerDependenciesMeta": {
    "@agent-assistant/harness": {
      "optional": true
    }
  },
  "devDependencies": {
    "@agent-assistant/harness": "^0.3.8",
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "repository": {
