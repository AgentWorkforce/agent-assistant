{
  "name": "@agent-assistant/specialists",
  "version": "0.3.12",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "npm run build",
    "prebuild": "npm --prefix ../coordination run build && npm --prefix ../vfs run build",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@agent-assistant/coordination": "^0.2.6",
    "@agent-assistant/vfs": "^0.2.6",
    "@relayfile/adapter-github": "^0.1.6",
    "@relayfile/adapter-linear": "^0.1.7"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentWorkforce/agent-assistant"
  },
  "publishConfig": {
    "access": "public"
  }
}
